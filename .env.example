# Copy this file to `.env` and fill in real values.

DATABASE_URL="file:./dev.db"
AUTH_SECRET="use-a-long-random-string-in-production"
AUTH_TRUST_HOST=true
QR_TOKEN_ROTATION_MS=8000
QR_TOKEN_TTL_MS=12000

# Resend API key for sending the password-setup email to newly created users.
# Get one at https://resend.com/api-keys. If this is missing or invalid, user
# creation still succeeds — the email is best-effort and the setup link is
# always shown to the admin as a fallback (see src/lib/email.ts).
RESEND_API_KEY="re_your_key_here"
